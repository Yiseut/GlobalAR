__pycache__/
*.py[cod]
*.pyo
*.pyd

.playwright-cli/
.pytest_cache/
node_modules/
video-demo/node_modules/

# Runtime and generated bulk artifacts.
output/
visual-check/
assets/company_media/
assets/official_media/

# Continuous verification data is large and changes while the runner is active.
data/*
!data/audits/
!data/audits/**
!data/company_logo_manifest.csv
!data/company_logo_report.md

# Generated dashboard data snapshots are rebuilt from source data.
web/app-data.js

# Copied profile/product imagery can be regenerated from local asset sources.
web/assets/company_profiles/
!web/assets/company_logos/
!web/assets/company_logos/**

# Local archive of old process snapshots (multi-GB; never push to remote).
_archive/
# SQLite databases are regenerated by build_data.py from the source workbook.
*.db
*.sqlite
*.sqlite3
# Point-in-time workbook/evidence backups (40MB+ each, regenerable).
*backup_before*
